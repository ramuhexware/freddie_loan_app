<?xml version="1.0" encoding="UTF-8" ?>
<process name="LoanApprovalProcess"
         targetNamespace="http://xmlns.oracle.com/FreddieApp/LoanApprovalProcess"
         xmlns="http://docs.oasis-open.org/wsbpel/2.0/process/executable"
         xmlns:client="http://xmlns.oracle.com/FreddieApp/LoanApprovalProcess"
         xmlns:legacy="http://xmlns.oracle.com/FreddieApp/LegacySoapService"
         xmlns:bpelx="http://schemas.oracle.com/bpel/extension"
         xmlns:bpel="http://docs.oasis-open.org/wsbpel/2.0/process/executable"
         xmlns:xp20="http://www.oracle.com/XSL/Transform/java/oracle.tip.pc.services.functions.Xpath20"
         xmlns:oraext="http://www.oracle.com/XSL/Transform/java/oracle.tip.pc.services.functions.ExtFunc"
         xmlns:dvm="http://www.oracle.com/XSL/Transform/java/oracle.tip.dvm.LookupValue"
         xmlns:hwf="http://xmlns.oracle.com/bpel/workflow/xpath"
         xmlns:ids="http://xmlns.oracle.com/bpel/services/IdentityService/xpath"
         xmlns:bpm="http://xmlns.oracle.com/bpmn20/extensions"
         xmlns:ess="http://xmlns.oracle.com/scheduler"
         xmlns:xdk="http://schemas.oracle.com/bpel/extension/xpath/function/xdk"
         xmlns:xref="http://www.oracle.com/XSL/Transform/java/oracle.tip.xref.xpath.XRefLookup"
         xmlns:ldap="http://schemas.oracle.com/xpath/extension/ldap">

    <!-- Partner Links -->
    <partnerLinks>
        <partnerLink name="loanapprovalprocess_client"
                     partnerLinkType="client:LoanApprovalProcessPartnerLinkType"
                     myRole="LoanApprovalProcessProvider"/>
        <partnerLink name="LegacyEligibilityServiceRef"
                     partnerLinkType="legacy:LegacySoapPartnerLinkType"
                     partnerRole="EligibilityServiceProvider"/>
    </partnerLinks>

    <!-- Variables -->
    <variables>
        <variable name="inputVar" messageType="client:LoanApprovalRequestMessage"/>
        <variable name="outputVar" messageType="client:LoanApprovalResponseMessage"/>
        <variable name="legacyRequest" messageType="legacy:EligibilityRequestMessage"/>
        <variable name="legacyResponse" messageType="legacy:EligibilityResponseMessage"/>
    </variables>

    <!-- Orchestration Sequence -->
    <sequence name="main">

        <!-- Receive Loan Request from Client -->
        <receive name="receiveInput" partnerLink="loanapprovalprocess_client"
                 portType="client:LoanApprovalProcessPortType" operation="process"
                 variable="inputVar" createInstance="yes"/>

        <scope name="UnderwritingDecisionScope">
            <sequence name="Sequence1">
                <!-- Step 1: Credit Score Pre-qualification Gate -->
                <if name="CheckCreditScore">
                    <condition>$inputVar.payload/client:creditScore &lt; 600</condition>
                    <sequence name="AutoRejectionSequence">
                        <!-- Auto-decline if credit score is below threshold -->
                        <assign name="AssignDeclineResponse">
                            <copy>
                                <from>$inputVar.payload/client:loanId</from>
                                <to>$outputVar.payload/client:loanId</to>
                            </copy>
                            <copy>
                                <from>false()</from>
                                <to>$outputVar.payload/client:approved</to>
                            </copy>
                            <copy>
                                <from>0.0</from>
                                <to>$outputVar.payload/client:interestRate</to>
                            </copy>
                            <copy>
                                <from>'HIGH'</from>
                                <to>$outputVar.payload/client:riskLevel</to>
                            </copy>
                            <copy>
                                <from>'FICO credit score below minimum pre-qualification gate (600).'</from>
                                <to>$outputVar.payload/client:decisionReason</to>
                            </copy>
                            <copy>
                                <from>'Auto-Declined by BPEL Pre-Qual Gate'</from>
                                <to>$outputVar.payload/client:orchestrationStatus</to>
                            </copy>
                            <copy>
                                <from>xp20:current-dateTime()</from>
                                <to>$outputVar.payload/client:timestamp</to>
                            </copy>
                        </assign>
                    </sequence>
                    <else>
                        <!-- Proceed with Calling Legacy OSB Service -->
                        <sequence name="LegacyVerificationSequence">
                            
                            <!-- Assign variables to Legacy Service Request payload -->
                            <assign name="AssignLegacyRequest">
                                <copy>
                                    <from>$inputVar.payload/client:loanId</from>
                                    <to>$legacyRequest.payload/legacy:loanId</to>
                                </copy>
                                <copy>
                                    <from>$inputVar.payload/client:customerId</from>
                                    <to>$legacyRequest.payload/legacy:customerId</to>
                                </copy>
                                <copy>
                                    <from>$inputVar.payload/client:loanAmount</from>
                                    <to>$legacyRequest.payload/legacy:loanAmount</to>
                                </copy>
                                <copy>
                                    <from>$inputVar.payload/client:creditScore</from>
                                    <to>$legacyRequest.payload/legacy:creditScore</to>
                                </copy>
                                <!-- DTI Formula: (Monthly Debt / Annual Income * 12) * 100 -->
                                <copy>
                                    <from>($inputVar.payload/client:monthlyDebt div ($inputVar.payload/client:annualIncome div 12.0)) * 100.0</from>
                                    <to>$legacyRequest.payload/legacy:monthlyDti</to>
                                </copy>
                            </assign>

                            <!-- Invoke Legacy SOAP Endpoint through OSB Link -->
                            <invoke name="InvokeLegacyOSB" partnerLink="LegacyEligibilityServiceRef"
                                    portType="legacy:LegacySoapPortType" operation="checkEligibility"
                                    inputVariable="legacyRequest" outputVariable="legacyResponse"/>

                            <!-- Assign Response fields based on Legacy evaluation -->
                            <assign name="AssignOrchestratedResponse">
                                <copy>
                                    <from>$inputVar.payload/client:loanId</from>
                                    <to>$outputVar.payload/client:loanId</to>
                                </copy>
                                <copy>
                                    <from>$legacyResponse.payload/legacy:eligible</from>
                                    <to>$outputVar.payload/client:approved</to>
                                </copy>
                                <copy>
                                    <from>$legacyResponse.payload/legacy:baseRate</from>
                                    <to>$outputVar.payload/client:interestRate</to>
                                </copy>
                                <copy>
                                    <from>
                                        <literal>
                                            <xs:string xmlns:xs="http://www.w3.org/2001/XMLSchema">
                                                $inputVar.payload/client:creditScore &gt;= 740 ? 'LOW' : 'MEDIUM'
                                            </xs:string>
                                        </literal>
                                    </from>
                                    <!-- Dynamic evaluation based on FICO -->
                                    <to>$outputVar.payload/client:riskLevel</to>
                                </copy>
                                <copy>
                                    <from>$legacyResponse.payload/legacy:comments</from>
                                    <to>$outputVar.payload/client:decisionReason</to>
                                </copy>
                                <copy>
                                    <from>'Orchestrated Successfully via BPEL Process'</from>
                                    <to>$outputVar.payload/client:orchestrationStatus</to>
                                </copy>
                                <copy>
                                    <from>xp20:current-dateTime()</from>
                                    <to>$outputVar.payload/client:timestamp</to>
                                </copy>
                            </assign>
                        </sequence>
                    </else>
                </if>
            </sequence>
        </scope>

        <!-- Send Response back to client -->
        <reply name="replyOutput" partnerLink="loanapprovalprocess_client"
               portType="client:LoanApprovalProcessPortType" operation="process"
               variable="outputVar"/>

    </sequence>
</process>
