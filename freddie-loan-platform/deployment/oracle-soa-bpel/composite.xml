<?xml version="1.0" encoding="UTF-8"?>
<composite name="LoanApprovalComposite"
           revision="1.0"
           label="loan_approval_orchestrator"
           mode="active"
           state="on"
           xmlns="http://xmlns.oracle.com/sca/1.0"
           xmlns:ui="http://xmlns.oracle.com/soa/designer/"
           xmlns:xs="http://www.w3.org/2001/XMLSchema">

    <import namespace="http://xmlns.oracle.com/FreddieApp/LoanApprovalProcess"
            location="LoanApprovalProcess.wsdl" importType="wsdl"/>
    <import namespace="http://xmlns.oracle.com/FreddieApp/LegacySoapService"
            location="LegacySoapService.wsdl" importType="wsdl"/>

    <!-- Service Exposed to API Gateway/OSB -->
    <service name="LoanApprovalService" ui:wsdlLocation="LoanApprovalProcess.wsdl">
        <interface.wsdl interface="http://xmlns.oracle.com/FreddieApp/LoanApprovalProcess#wsdl.interface(LoanApprovalProcessPortType)"/>
        <binding.ws port="http://xmlns.oracle.com/FreddieApp/LoanApprovalProcess#wsdl.endpoint(LoanApprovalService/LoanApprovalProcessPort)"/>
    </service>

    <property name="productVersion" type="xs:string" many="false">12.2.1.4.0</property>
    <property name="compositeID" type="xs:string" many="false">c4b31e0f-90e8-48b2-b108-9df2c29bde89</property>

    <!-- BPEL Component containing Orchestration Workflow -->
    <component name="LoanApprovalProcess" version="2.0">
        <implementation.bpel src="LoanApprovalProcess.bpel"/>
        <componentType>
            <service name="loanapprovalprocess_client" ui:wsdlLocation="LoanApprovalProcess.wsdl">
                <interface.wsdl interface="http://xmlns.oracle.com/FreddieApp/LoanApprovalProcess#wsdl.interface(LoanApprovalProcessPortType)"/>
            </service>
            <reference name="LegacyEligibilityServiceRef" ui:wsdlLocation="LegacySoapService.wsdl">
                <interface.wsdl interface="http://xmlns.oracle.com/FreddieApp/LegacySoapService#wsdl.interface(LegacySoapPortType)"/>
            </reference>
        </componentType>
    </component>

    <!-- Reference Link to SOAP Legacy System (via OSB Endpoint) -->
    <reference name="LegacyEligibilityServiceRef" ui:wsdlLocation="LegacySoapService.wsdl">
        <interface.wsdl interface="http://xmlns.oracle.com/FreddieApp/LegacySoapService#wsdl.interface(LegacySoapPortType)"/>
        <binding.ws port="http://xmlns.oracle.com/FreddieApp/LegacySoapService#wsdl.endpoint(LegacySoapService/LegacySoapPort)"
                    location="http://osb-host:7001/osbws/LoanEligibilityService?WSDL">
            <property name="weblogic.wsee.wsat.transaction.flowOption" type="xs:string" many="false">WSDLDriven</property>
        </binding.ws>
    </reference>

    <!-- SCA Wire connects BPEL Component Reference to External SOAP Service -->
    <wire>
        <source.uri>LoanApprovalProcess/LegacyEligibilityServiceRef</source.uri>
        <target.uri>LegacyEligibilityServiceRef</target.uri>
    </wire>
    <wire>
        <source.uri>LoanApprovalService</source.uri>
        <target.uri>LoanApprovalProcess/loanapprovalprocess_client</target.uri>
    </wire>

</composite>
